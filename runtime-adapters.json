{
  "version": "1",
  "protocolVersion": "compute.v1alpha1",
  "adapters": [
    {
      "adapterId": "sandboxed-command",
      "operation": "run-sandboxed-command",
      "kinds": ["execution"],
      "workloadKinds": ["command"],
      "runtimeProfiles": ["sandboxed-oci-v1"],
      "workspacePolicy": "required",
      "conformanceProfiles": ["sandboxed-command-v1"]
    },
    {
      "adapterId": "sandboxed-container-build",
      "operation": "build-sandboxed-container",
      "kinds": ["execution"],
      "workloadKinds": ["container-build"],
      "runtimeProfiles": ["container-build-v1"],
      "workspacePolicy": "required",
      "conformanceProfiles": ["container-build-v1"]
    }
  ],
  "hostOwnedResponsibilities": [
    "task-admission",
    "leases",
    "authorization",
    "credential-resolution",
    "registry-allowlists",
    "proof-reward-mutation",
    "worker-binding"
  ]
}
