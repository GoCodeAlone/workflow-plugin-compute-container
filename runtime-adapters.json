{
  "version": "1",
  "protocol_version": "compute.v1alpha1",
  "adapters": [
    {
      "adapter_id": "sandboxed-command",
      "operation": "run-sandboxed-command",
      "kinds": ["execution"],
      "workload_kinds": ["command"],
      "runtime_profiles": ["sandboxed-oci-v1"],
      "workspace_policy": "required",
      "conformance_profiles": ["sandboxed-command-v1"]
    },
    {
      "adapter_id": "sandboxed-container-build",
      "operation": "build-sandboxed-container",
      "kinds": ["execution"],
      "workload_kinds": ["container-build"],
      "runtime_profiles": ["container-build-v1"],
      "workspace_policy": "required",
      "conformance_profiles": ["container-build-v1"]
    }
  ],
  "runtime_backends": [
    {
      "backend_id": "podman-rootless",
      "families": ["podman"],
      "tools": ["podman"],
      "isolation_modes": ["user-namespace"],
      "install_burdens": ["system-installed"],
      "runtime_profiles": ["sandboxed-oci-v1", "container-build-v1"],
      "executor_providers": ["sandboxed-command", "sandboxed-container-build"],
      "conformance_profiles": ["distroless-static-v1"]
    },
    {
      "backend_id": "docker-desktop",
      "families": ["docker"],
      "tools": ["docker"],
      "isolation_modes": ["vm-backed-container"],
      "install_burdens": ["desktop-managed"],
      "runtime_profiles": ["sandboxed-oci-v1", "container-build-v1"],
      "executor_providers": ["sandboxed-command", "sandboxed-container-build"],
      "conformance_profiles": ["distroless-static-v1"]
    },
    {
      "backend_id": "nerdctl-containerd",
      "families": ["nerdctl", "containerd"],
      "tools": ["nerdctl"],
      "isolation_modes": ["shared-kernel-container"],
      "install_burdens": ["system-installed"],
      "runtime_profiles": ["sandboxed-oci-v1", "container-build-v1"],
      "executor_providers": ["sandboxed-command", "sandboxed-container-build"],
      "conformance_profiles": ["distroless-static-v1"]
    },
    {
      "backend_id": "managed-containerd-linux-amd64",
      "families": ["containerd"],
      "tools": ["nerdctl"],
      "supported_targets": [
        {
          "os": "linux",
          "arch": "amd64"
        }
      ],
      "isolation_modes": ["user-namespace"],
      "install_burdens": ["bundled"],
      "runtime_profiles": ["sandboxed-oci-v1", "container-build-v1"],
      "executor_providers": ["sandboxed-command", "sandboxed-container-build"],
      "conformance_profiles": ["distroless-static-v1"]
    }
  ],
  "host_owned_responsibilities": [
    "task-admission",
    "leases",
    "authorization",
    "credential-resolution",
    "registry-allowlists",
    "proof-reward-mutation",
    "worker-binding"
  ]
}
