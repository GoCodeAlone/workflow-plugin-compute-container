{
  "version": "1",
  "contracts": [
    {
      "name": "ManagedRuntimeBundleInstaller",
      "wire": "json",
      "goType": "github.com/GoCodeAlone/workflow-plugin-compute-container/container.ManagedRuntimeBundleInstaller",
      "commands": [
        "managed-runtime install",
        "managed-runtime doctor",
        "managed-runtime uninstall",
        "managed-runtime reinstall"
      ],
      "produces": [
        "ManagedRuntimeInstallResult",
        "ManagedRuntimeDoctorResult",
        "ManagedRuntimeUninstallResult",
        "ManagedRuntimeReinstallResult"
      ],
      "guarantees": [
        "scoped-install-root",
        "pinned-artifact-checksum-signature-digests",
        "safe-tar-gzip-extraction",
        "scoped-uninstall-only"
      ]
    }
  ],
  "protocolTypes": [
    {
      "name": "RuntimeBackendReport",
      "wire": "json",
      "goType": "github.com/GoCodeAlone/workflow-plugin-compute-core/protocol.RuntimeBackendReport",
      "protocolVersion": "compute.v1alpha1",
      "producedBy": ["DockerCompatibleRuntimeProbes", "ManagedContainerdRuntimeProbe"]
    },
    {
      "name": "ManagedRuntimeBundleCatalog",
      "wire": "json",
      "goType": "github.com/GoCodeAlone/workflow-plugin-compute-container/container.ManagedRuntimeBundleCatalog",
      "protocolVersion": "compute.v1alpha1",
      "producedBy": ["managed-runtime-bundles.json"]
    }
  ]
}
